# ── Use Node.js 20 ───────────────────────────────────────────
FROM node:20-slim AS base

# ── Set working directory ────────────────────────────────────
WORKDIR /app

# ── Install dependencies ─────────────────────────────────────
COPY package*.json ./
RUN npm install

# ── Copy source code ─────────────────────────────────────────
COPY . .

# ── Expose port 3000 ─────────────────────────────────────────
EXPOSE 3000

# ── Start the app ────────────────────────────────────────────
CMD ["node", "server/cloud_controller.js"]